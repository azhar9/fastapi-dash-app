# Copy to .env before running docker compose up.
# Defaults are safe for local development only.

# Postgres
POSTGRES_USER=gam
POSTGRES_PASSWORD=gam
POSTGRES_DB=gam
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Ports published to the host (for psql/redis-cli/curl from your laptop).
# Defaults are deliberately high to avoid colliding with other local stacks.
POSTGRES_HOST_PORT=55432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=56379

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8088
API_LOG_LEVEL=INFO
API_CACHE_TTL_SECONDS=300
API_BASE_URL=http://api:8000

# Dash
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_HOST_PORT=8050
DASH_DEBUG=false

# LLM (natural-language → SQL on the /ask endpoint).
# Provider is Groq via OpenAI-compatible API. The key is intentionally
# blank in this example; set it in your local .env (which is git-ignored).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Read-only PG role created by db/init/002_ro_role.sql. Used *only* by the
# /ask endpoint. Password is the same as the role name by default.
POSTGRES_RO_USER=gam_ro
POSTGRES_RO_PASSWORD=gam_ro

# Seed job
SEED_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,BRK-B,JPM,V,JNJ,WMT,PG,XOM,UNH,HD,MA,BAC,PFE,KO,PEP,CVX,MRK,ABBV,CSCO,TMO,ORCL,ADBE,CRM,NFLX
SEED_BENCHMARK=SPY
SEED_START_DATE=2022-01-01
